# Integration test environment — copy to .env.test and fill with the keys of a
# DEDICATED test Supabase project (NOT production). The integration suites in
# tests/*.test.ts mutate real data, so they run against this project only.
#
# A guard in tests/helpers/testEnv.ts refuses to run if the URL points at the
# production project. See tests/README.md for the full setup walkthrough.

VITE_SUPABASE_URL=https://YOUR_TEST_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_TEST_PROJECT_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_TEST_PROJECT_SERVICE_ROLE_KEY
