# BranchMatch — environment variables
# Copy to .env and fill in the values from the Supabase dashboard
# (Project Settings → API). VITE_* values are public and shipped to the browser.

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Server-side only — used by the integration tests (tests/) and maintenance
# scripts (scripts/). NEVER expose this in frontend code or commit it.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Comma-separated list of admin emails (UX hint only; real admin gating is
# done by the is_admin() function in the database).
VITE_ADMIN_EMAILS=admin@example.com
